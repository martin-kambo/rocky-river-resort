# ─────────────────────────────────────────────────────────────────────────────
# Rocky River Resort — Environment Variables
# Copy to .env  ·  Never commit .env to version control
# Generate secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (Render PostgreSQL) ─────────────────────────────────────────────
# Render injects DATABASE_URL automatically from render.yaml's fromDatabase binding.
# For local development use docker-compose.yml.
DATABASE_URL=postgresql://rrr_user:your_password@localhost:5432/rocky_river_resort
POSTGRES_USER=rrr_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=rocky_river_resort

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_string
JWT_REFRESH_SECRET=replace_with_different_64_char_random_string
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

# ─── Email — Resend ───────────────────────────────────────────────────────────
# resend.com → Add API Key · Verify your sending domain before production
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Rocky River Resort <hello@rockyriverresort.co.ke>

# ─── Payments — Stripe ────────────────────────────────────────────────────────
# dashboard.stripe.com/apikeys · use sk_test_ for dev, sk_live_ for production
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_
# Local webhook testing: stripe listen --forward-to localhost:4000/api/v1/payments/webhook/stripe

# ─── Payments — M-Pesa Daraja ─────────────────────────────────────────────────
# developer.safaricom.co.ke → Create app → enable Lipa Na M-Pesa Online
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
# Local callback testing: use ngrok — ngrok http 4000
MPESA_CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/v1/payments/webhook/mpesa

# ─── Media — Cloudinary ───────────────────────────────────────────────────────
# cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── App URLs ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── API Server ───────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000