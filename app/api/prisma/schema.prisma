generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────
enum UserRole {
  guest
  staff
  admin
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentProvider {
  STRIPE
  MPESA
  PAYPAL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum RoomStatus {
  available
  occupied
  maintenance
}

enum ViewType {
  river
  pool
  garden
}

enum BlockReason {
  booked
  blocked
  maintenance
}

enum BookingSource {
  website
  phone
  walk_in
  ota
}

// ─── Models ─────────────────────────────────────────────────────────────────
model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String?
  firstName        String    @db.VarChar(100)
  lastName         String    @db.VarChar(100)
  phone            String?   @db.VarChar(20)
  role             UserRole  @default(guest)
  nationality      String?   @db.VarChar(3)
  preferredLocale  String    @default("en") @db.VarChar(5)
  oauthProvider    String?
  oauthId          String?
  emailVerifiedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  bookings         Booking[]
  refreshTokens    RefreshToken[]
  reviews          Review[]

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique @db.VarChar(512)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model RoomType {
  id            String   @id @default(uuid())
  slug          String   @unique
  nameEn        String   @db.VarChar(100)
  nameSw        String   @db.VarChar(100)
  descriptionEn String   @db.Text
  descriptionSw String   @db.Text
  basePriceKes  Decimal  @db.Decimal(10, 2)
  basePriceUsd  Decimal  @db.Decimal(10, 2)
  maxOccupancy  Int      @db.SmallInt
  sizeSqm       Decimal  @db.Decimal(6, 2)
  amenities     String[]
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rooms            Room[]
  images           RoomImage[]
  seasonalPricing  SeasonalPricing[]

  @@map("room_types")
}

model RoomImage {
  id         String   @id @default(uuid())
  roomTypeId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  url        String
  altEn      String   @db.VarChar(255)
  altSw      String   @db.VarChar(255)
  sortOrder  Int      @default(0)
  isHero     Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([roomTypeId])
  @@map("room_images")
}

model Room {
  id           String     @id @default(uuid())
  roomTypeId   String
  roomType     RoomType   @relation(fields: [roomTypeId], references: [id])
  roomNumber   String     @db.VarChar(10)
  floor        Int        @db.SmallInt
  viewType     ViewType
  status       RoomStatus @default(available)
  notes        String?    @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  bookings           Booking[]
  availabilityBlocks AvailabilityBlock[]

  @@unique([roomNumber])
  @@index([roomTypeId, status])
  @@map("rooms")
}

model Booking {
  id              String        @id @default(uuid())
  reference       String        @unique @db.VarChar(12)
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  roomId          String
  room            Room          @relation(fields: [roomId], references: [id])
  checkIn         DateTime      @db.Date
  checkOut        DateTime      @db.Date
  nights          Int           @db.SmallInt
  adults          Int           @db.SmallInt
  children        Int           @default(0) @db.SmallInt
  status          BookingStatus @default(PENDING)
  totalKes        Decimal       @db.Decimal(12, 2)
  totalUsd        Decimal       @db.Decimal(12, 2)
  specialRequests String?       @db.Text
  source          BookingSource @default(website)
  createdAt       DateTime      @default(now())
  confirmedAt     DateTime?
  updatedAt       DateTime      @updatedAt

  payments           Payment[]
  availabilityBlocks AvailabilityBlock[]
  review             Review?

  @@index([userId])
  @@index([roomId, checkIn, checkOut])
  @@index([status])
  @@map("bookings")
}

model Payment {
  id          String          @id @default(uuid())
  bookingId   String
  booking     Booking         @relation(fields: [bookingId], references: [id])
  provider    PaymentProvider
  providerRef String          @db.VarChar(255)
  amount      Decimal         @db.Decimal(12, 2)
  currency    String          @db.Char(3)
  status      PaymentStatus   @default(PENDING)
  payload     Json?
  paidAt      DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([bookingId])
  @@index([providerRef])
  @@map("payments")
}

model AvailabilityBlock {
  id        String      @id @default(uuid())
  roomId    String
  room      Room        @relation(fields: [roomId], references: [id])
  startDate DateTime    @db.Date
  endDate   DateTime    @db.Date
  reason    BlockReason
  bookingId String?
  booking   Booking?    @relation(fields: [bookingId], references: [id])
  createdAt DateTime    @default(now())

  @@index([roomId, startDate, endDate])
  @@map("availability_blocks")
}

model SeasonalPricing {
  id         String   @id @default(uuid())
  roomTypeId String
  roomType   RoomType @relation(fields: [roomTypeId], references: [id])
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  multiplier Decimal  @default(1.0) @db.Decimal(4, 2)
  label      String?  @db.VarChar(100)
  createdAt  DateTime @default(now())

  // Unique constraint enables idempotent upserts in seed and admin
  @@unique([roomTypeId, startDate, endDate])
  @@index([roomTypeId, startDate, endDate])
  @@map("seasonal_pricing")
}

model Review {
  id          String    @id @default(uuid())
  bookingId   String    @unique
  booking     Booking   @relation(fields: [bookingId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  rating      Int       @db.SmallInt   // 1–5; enforced in DTO + checked in service
  comment     String    @db.Text
  publishedAt DateTime?
  createdAt   DateTime  @default(now())

  @@map("reviews")
}