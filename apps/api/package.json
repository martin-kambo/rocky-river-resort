{
  "name": "@rrr/api",
  "version": "1.0.0",
  "scripts": {
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "build": "nest build",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:cov": "jest --coverage",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
  "@types/bcryptjs":    "^2.4.6",
  "@types/express":     "^4.17.21",
  "@types/multer":      "^1.4.11",
  "@types/passport-jwt":"^4.0.1",
  "@nestjs/common": "^11.1.28",
  "@nestjs/config": "^4.0.4",
  "@nestjs/core": "^11.1.28",
  "@nestjs/jwt": "^11.0.2",
  "@nestjs/passport": "^11.0.5",
  "@nestjs/platform-express": "^11.1.28",
  "@nestjs/swagger": "^11.4.5",
  "@nestjs/throttler": "^6.5.0",
  "@prisma/client": "5.22.0",
  "@rrr/types": "*",
  "@rrr/utils": "*",
  "axios": "^1.7.2",
  "bcryptjs": "^2.4.3",
  "class-transformer": "^0.5.1",
  "class-validator": "^0.14.1",
  "cloudinary": "^2.2.0",
  "date-fns": "^3.6.0",
  "helmet": "^7.1.0",
  "multer": "^2.2.0",
  "next": "^16.2.10",
  "next-intl": "4.13.2",
  "passport": "^0.7.0",
  "passport-jwt": "^4.0.1",
  "prisma": "5.22.0",
  "reflect-metadata": "^0.2.2",
  "resend": "^3.2.0",
  "rxjs": "^7.8.1",
  "stripe": "^15.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/testing": "^11.1.28",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.module.ts",
      "!**/main.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "@rrr/types": "<rootDir>/../../packages/types/src",
      "@rrr/utils": "<rootDir>/../../packages/utils/src"
    }
  }
}
